{
  "name": "@interfluo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run copy:pdf-worker && next dev -p 3000",
    "build": "pnpm run copy:pdf-worker && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint --max-warnings=0 || biome check src",
    "clean": "rm -rf .next .turbo",
    "copy:pdf-worker": "node -e \"require('fs').copyFileSync(require.resolve('pdfjs-dist/build/pdf.worker.min.mjs'), 'public/pdf.worker.min.mjs')\"",
    "postinstall": "pnpm run copy:pdf-worker"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.10.4",
    "@interfluo/core": "workspace:*",
    "@interfluo/sdk": "workspace:*",
    "clsx": "^2.1.1",
    "next": "15.1.4",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@interfluo/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
