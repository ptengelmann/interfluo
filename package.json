{
  "name": "interfluo",
  "version": "0.1.0",
  "private": true,
  "description": "AI co-pilot for residential conveyancing fee-earners",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:fresh": "rm -rf apps/*/.next apps/*/.turbo && pnpm dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.10.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@clerk/shared", "esbuild", "sharp"]
  }
}
